{
  "id": "arrow",
  "name": "Arrow",
  "version": "1.0.1",
  "manifestVersion": 1,
  "discVaultPluginApi": "next-1",
  "minimumDiscVaultVersion": "26.4.63",
  "categories": ["price_provider"],
  "capabilities": ["price_check"],
  "priceProvider": {
    "hostPatterns": ["arrowfilms.", "arrow-video."]
  },
  "requiresSecrets": false,
  "settingsSchemaVersion": 1,
  "settingsSchema": {
    "settings": [
      {
        "name": "currency",
        "label": "Fallback currency",
        "type": "text",
        "required": false,
        "placeholder": "GBP",
        "description": "Fallback currency when the shop page does not expose one."
      },
      {
        "name": "timeoutSeconds",
        "label": "HTTP timeout (seconds)",
        "type": "number",
        "required": false,
        "placeholder": "20",
        "description": "Request timeout used when fetching Arrow product pages."
      }
    ]
  },
  "defaultEnabled": false,
  "orderIndex": 200,
  "entitlements": {
    "source_use": "price_provider.arrow.use"
  }
}
