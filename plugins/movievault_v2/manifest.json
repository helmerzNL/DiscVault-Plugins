{
  "id": "movievault_v2",
  "name": "MovieVault v2",
  "version": "1.3.2",
  "manifestVersion": 1,
  "discVaultPluginApi": "next-1",
  "minimumDiscVaultVersion": "26.5.10",
  "distributionContractRange": {
    "minimum": "distribution-2",
    "maximum": "distribution-4"
  },
  "categories": [
    "metadata_source"
  ],
  "capabilities": [
    "health_check",
    "sync_index",
    "search_barcode",
    "search_title",
    "movie_details",
    "box_set_candidates"
  ],
  "requiresSecrets": false,
  "settingsSchemaVersion": 1,
  "settingsSchema": {
    "settings": [
      {
        "name": "origin",
        "label": "MovieVault v2 origin",
        "type": "url",
        "required": true,
        "default": "https://movies2.vaultstack.eu",
        "placeholder": "https://movies2.vaultstack.eu",
        "description": "Origin of the MovieVault v2 service. Do not include a path."
      }
    ],
    "secrets": []
  },
  "defaultEnabled": false,
  "orderIndex": 52,
  "premiumFeatureKey": "metadata.source.movievault.use",
  "entitlements": {
    "source_use": "metadata.source.movievault.use",
    "source_bulk": "metadata.source.movievault.bulk"
  }
}
